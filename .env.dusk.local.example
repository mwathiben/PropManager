# Dusk E2E Test Environment
# Copy to .env.dusk.local and generate your own APP_KEY:
#   cp .env.dusk.local.example .env.dusk.local
#   php artisan key:generate --env=dusk.local
#
# NEVER commit .env.dusk.local — it is gitignored.

APP_NAME="PropManager Test"
APP_ENV=testing
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=database/dusk.sqlite

SESSION_DRIVER=file
QUEUE_CONNECTION=sync

MAIL_MAILER=log

# Payment credentials are per-tenant and must be stored in database.
# See: PaymentConfigurationFactory for test seeding
# See: tests/Traits/MocksExternalServices.php for mocking patterns
# NEVER put per-tenant API keys in .env files

# CSP is enabled by default (config/security.php defaults to true).
# Uncomment to explicitly control:
# SECURITY_CSP_ENABLED=true
