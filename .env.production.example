# Phase-11 SECRETS-8: production-safe defaults template.
#
# Copy this file to .env on a production host, then fill in the
# REAL secret values (anything blank below). The toggles are already
# flipped for production — copying .env.example (the local-dev
# template) and forgetting to flip ~30 booleans is the typical
# production-launch failure mode this file exists to prevent.
#
# The production-config validator (AppServiceProvider::
# validateProductionSecurity) will REFUSE TO BOOT if APP_DEBUG=true
# under APP_ENV != local, or if SESSION_ENCRYPT / SESSION_SECURE_COOKIE
# is disabled, or if MAIL_MAILER is log/array. So the safe defaults
# below match what the validator will accept.

APP_NAME=PropManager
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://CHANGEME.example.com
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=strict

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=
REDIS_PASSWORD=
REDIS_PORT=6379

# DO NOT use mail.mailer=log in production. Validator throws on log/array.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

MPESA_STK_CALLBACK_URL="${APP_URL}/webhooks/mpesa/stk-callback"
INTASEND_PLATFORM_WALLET_ID=

VITE_APP_NAME="${APP_NAME}"

# Phase-5 CRYPTO-12: must be set in production; validator refuses
# the historical placeholder strings.
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=
REVERB_PORT=443
REVERB_SCHEME=https

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

SECURITY_HSTS_ENABLED=true
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_HSTS_SUBDOMAINS=true
SECURITY_CSP_ENABLED=true
SECURITY_X_FRAME_OPTIONS=DENY

RATE_LIMIT_LOGIN=5,1
RATE_LIMIT_REGISTER=3,1
RATE_LIMIT_API=60,1

PASSWORD_MIN_LENGTH=12
PASSWORD_CHECK_BREACHED=true

TWO_FACTOR_ENABLED=true
TWO_FACTOR_ISSUER="${APP_NAME}"

SECURITY_LOGGING_ENABLED=true
SECURITY_LOG_RETENTION_DAYS=90

AUDIT_ENABLED=true
AUDIT_RETENTION_DAYS=365

GDPR_ENABLED=true
KENYA_DPA_ENABLED=true
DELETION_GRACE_DAYS=30
DATA_RETENTION_YEARS=7

SAML_ENABLED=false
SAML_SP_ENTITY_ID=
SAML_SP_ACS_URL=

INTRUSION_DETECTION_ENABLED=true
FAILED_LOGIN_THRESHOLD=5
LOCKOUT_DURATION=15

# Kenya DPA: registration number must be set before going live.
KENYA_DPA_REGISTRATION=
KENYA_DPA_BREACH_EMAIL=
KENYA_DPA_ODPC_EMAIL=info@odpc.go.ke
KENYA_DPA_CROSS_BORDER_CONSENT=true

# Phase-5 OBS-1 / Phase-11 SECRETS-3: empty DSN = silent no-op. Set
# to the real Sentry project DSN before launching.
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0

WHATSAPP_PAYMENT_LINKS_ENABLED=false
