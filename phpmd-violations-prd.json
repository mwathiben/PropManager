{
  "project": {
    "name": "PropManager PHPMD Violations Remediation",
    "description": "Systematic elimination of PHPMD code quality violations. 228 violations across 90 files, grouped into 52 actionable items.",
    "version": "1.0.0"
  },
  "qualityStandards": {
    "description": "Systematic code quality improvement through complexity reduction and pattern application.",
    "principles": [
      "Write failing test FIRST (RED-GREEN-REFACTOR) before refactoring",
      "Refactor only when tests pass - ensure no regressions",
      "Extract one responsibility at a time",
      "Use existing patterns from prior refactoring (see CLAUDE.md Code Complexity Guidelines)",
      "All new extracted classes must have Factories for testing"
    ],
    "thresholds": {
      "cyclomaticComplexity": 7,
      "npathComplexity": 200,
      "methodLength": 80,
      "classLength": 400,
      "parameterCount": 5,
      "publicCount": 20
    },
    "strategies": {
      "cyclomaticComplexity": "Extract methods, use early returns, replace conditionals with polymorphism",
      "excessiveParameterList": "Create DTOs/value objects to group related parameters",
      "excessiveMethodLength": "Extract focused helper methods",
      "excessiveClassLength": "Extract services/transformers/builders",
      "npathComplexity": "Reduce nesting, simplify branching logic",
      "excessivePublicCount": "Review API surface, extract concerns (note: Eloquent models may be unavoidable)"
    },
    "skills_to_apply": [
      "laravelcomplexity-guardrails",
      "laraveltdd-with-pest",
      "verification-first",
      "laravelcontroller-cleanup",
      "laravelinterfaces-and-di",
      "laravelstrategy-pattern"
    ]
  },
  "feedbackLoops": {
    "description": "Run ALL feedback loops before committing. Do NOT commit if any fail.",
    "commands": {
      "phpmd": "./vendor/bin/phpmd app text phpmd.xml",
      "pint": "./vendor/bin/pint --test",
      "test": "php artisan test --parallel"
    },
    "verification": {
      "before_commit": [
        "All tests pass (php artisan test)",
        "Pint passes (vendor/bin/pint --test)",
        "PHPMD violation count reduced or unchanged",
        "Extracted classes have corresponding tests"
      ]
    }
  },
  "workflow": {
    "description": "Refactoring workflow for each PRD item - test-first approach",
    "steps": [
      {
        "step": 1,
        "name": "Ensure Existing Tests Pass",
        "description": "Before any refactoring, verify all existing tests pass. If tests fail, fix them first."
      },
      {
        "step": 2,
        "name": "Write Characterization Tests",
        "description": "If the code lacks tests, write characterization tests that capture current behavior before refactoring.",
        "example": "test('storeManual creates payment with valid data', function() { ... current behavior ... })"
      },
      {
        "step": 3,
        "name": "Extract and Refactor",
        "description": "Extract services/DTOs/helpers one at a time. Run tests after each extraction.",
        "checklist": [
          "Extract one class/method per commit",
          "Run tests after each extraction",
          "New classes get their own test files",
          "Follow existing patterns (see CLAUDE.md)"
        ]
      },
      {
        "step": 4,
        "name": "Verify PHPMD",
        "description": "Run PHPMD to confirm violations are reduced.",
        "command": "./vendor/bin/phpmd app text phpmd.xml"
      }
    ]
  },
  "categories": {
    "controller_critical": {
      "priority": 1,
      "description": "Controllers with 6+ violations - highest impact"
    },
    "service_critical": {
      "priority": 2,
      "description": "Services with 5+ violations"
    },
    "dto_introduction": {
      "priority": 3,
      "description": "Files with ExcessiveParameterList - quick wins with DTOs"
    },
    "controller_moderate": {
      "priority": 4,
      "description": "Controllers with 2-5 violations"
    },
    "service_moderate": {
      "priority": 5,
      "description": "Services with 2-4 violations"
    },
    "single_violations": {
      "priority": 6,
      "description": "Files with only 1 violation"
    },
    "model_review": {
      "priority": 7,
      "description": "Models with ExcessivePublicCount - may be acceptable"
    }
  },
