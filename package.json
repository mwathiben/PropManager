{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "node scripts/check-import-case.mjs && node scripts/check-import-exists.mjs && vite build",
        "dev": "vite",
        "lint": "eslint resources/js",
        "lint:baseline": "node scripts/lint-baseline.mjs",
        "check:imports": "node scripts/check-import-case.mjs && node scripts/check-import-exists.mjs",
        "test:a11y": "playwright test",
        "test:pwa": "playwright test --config playwright.pwa.config.ts",
        "test:rtl": "playwright test --config playwright.rtl.config.ts",
        "test:rtl:update": "playwright test --config playwright.rtl.config.ts --update-snapshots",
        "test:lhci": "lhci autorun --config=lighthouserc.cjs"
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.11.3",
        "@eslint/js": "^9.39.4",
        "@inertiajs/vue3": "^2.0.0",
        "@lhci/cli": "^0.15.1",
        "@playwright/test": "^1.60.0",
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/vite": "^4.3.0",
        "@typescript-eslint/parser": "^8.60.0",
        "@vitejs/plugin-vue": "^6.0.7",
        "axios": "^1.16.1",
        "concurrently": "^9.0.1",
        "eslint": "^9.39.4",
        "eslint-plugin-vuejs-accessibility": "^2.5.0",
        "laravel-echo": "^2.3.4",
        "laravel-vite-plugin": "^2.0.0",
        "postcss": "^8.5.15",
        "pusher-js": "^8.5.0",
        "tailwindcss": "^4.1.18",
        "typescript": "^5.9.3",
        "vite": "^7.0.7",
        "vite-plugin-pwa": "^1.3.0",
        "vue": "^3.5.35",
        "vue-eslint-parser": "^9.4.3",
        "workbox-window": "^7.4.1"
    },
    "dependencies": {
        "@floating-ui/vue": "^1.1.11",
        "@heroicons/vue": "^2.2.0",
        "@vueuse/core": "^14.3.0",
        "dompurify": "^3.4.7",
        "idb-keyval": "^6.2.4",
        "leaflet": "^1.9.4",
        "marked": "^17.0.1",
        "pinia": "^3.0.4",
        "vue-i18n": "^11.4.4",
        "ziggy-js": "^2.6.2",
        "zod": "^4.4.3"
    }
}
