APP_NAME=PropManager
APP_ENV=local
APP_KEY=
# SECRETS-2: default FALSE so a copy-and-deploy never leaks stack traces
# (the previous "true" default required every operator to remember the
# flip). Local devs opt in explicitly. The production validator throws
# if APP_DEBUG=true is detected with APP_ENV != local.
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# SECRETS-5: default to 'warning' so a copy-and-deploy doesn't leak
# query payloads (with bound PII) to log files in production. Local
# devs flip to 'debug' explicitly. Validator surfaces debug/info in
# production as a warning.
LOG_LEVEL=warning

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_HOST_READ=read-replica.example.com  # Optional: Read replica for heavy read workloads
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
# Set to true in production with HTTPS
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=strict

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
# Phase-58 SHARED-DISK-MIGRATION: tenant-scoped file storage. Flip to 's3'
# (or another configured disk) in production for horizontal scale. Default
# 'local' keeps dev/test green.
FILESYSTEM_TENANT_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ===========================================
# PAYSTACK CONFIGURATION
# ===========================================
# SECURITY NOTE: Per-landlord Paystack API keys are stored encrypted in the
# database via Settings > Payment Methods UI. This follows OWASP best practices
# for secrets management in multi-tenant SaaS applications.
#
# Landlords configure their own Paystack API keys in the Settings UI.
# Platform-level Paystack keys (if needed for admin/subscription billing)
# should be configured via Admin Dashboard, not this file.

# ===========================================
# M-PESA CONFIGURATION (Kenya)
# ===========================================
# SECURITY NOTE: Per-landlord M-Pesa API credentials (Consumer Key, Consumer Secret,
# Passkey) are stored encrypted in the database via Settings > Payment Methods UI.
# Only platform-level infrastructure settings belong in this file.

# mpesa_environment is per-landlord, stored in database (payment_configurations table)
# See: PaymentConfiguration::MPESA_ENVIRONMENTS for valid values

# STK Push callback URL (infrastructure - shared across all landlords)
MPESA_STK_CALLBACK_URL="${APP_URL}/webhooks/mpesa/stk-callback"

# C2B (Customer to Business) callback URLs (infrastructure - shared)
MPESA_C2B_VALIDATION_URL="${APP_URL}/webhooks/mpesa/c2b/validation"
MPESA_C2B_CONFIRMATION_URL="${APP_URL}/webhooks/mpesa/c2b/confirmation"

# B2C (Business to Customer - for refunds) callback URLs (infrastructure)
MPESA_B2C_RESULT_URL="${APP_URL}/webhooks/mpesa/b2c/result"
MPESA_B2C_TIMEOUT_URL="${APP_URL}/webhooks/mpesa/b2c/timeout"


# ===========================================
# INTASEND PLATFORM SETTINGS (SaaS Platform Level)
# ===========================================
# SECURITY NOTE: Platform API credentials and secrets are stored encrypted in
# the database via Admin Dashboard > Platform Settings, NOT in this file.
# This follows OWASP best practices for secrets management in multi-tenant SaaS.
#
# The following settings are configured via Admin Dashboard:
# - Platform Public Key (ISPubKey_*)
# - Platform Secret Key (ISSecretKey_*) - encrypted at rest
# - Webhook Secret - encrypted at rest
#
# Per-landlord API keys are stored in payment_configurations table via Settings UI.
# Docs: https://developers.intasend.com/docs

# Platform wallet ID for receiving split payment fees (PropManager's wallet)
# This is a public identifier, safe to store in .env
INTASEND_PLATFORM_WALLET_ID=


VITE_APP_NAME="${APP_NAME}"

# ===========================================
# LARAVEL REVERB (WebSocket Broadcasting)
# ===========================================

# CRYPTO-12: leave the secret BLANK in committed .env.example. The
# previous placeholder was a real-looking string, so a careless deploy
# that did not override it would ship with a known weak value. The
# AppServiceProvider production-config validator already rejects empty
# critical secrets at boot, so a forgotten override fails fast.
REVERB_APP_ID=propmanager
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

# Frontend WebSocket connection (Vite)
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ===========================================
# SECURITY CONFIGURATION
# ===========================================

# Security Headers (enable in production with HTTPS)
SECURITY_HSTS_ENABLED=false
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_HSTS_SUBDOMAINS=true
SECURITY_CSP_ENABLED=true
SECURITY_X_FRAME_OPTIONS=DENY

# Rate Limiting (attempts per minute)
RATE_LIMIT_LOGIN=5,1
RATE_LIMIT_REGISTER=3,1
RATE_LIMIT_API=60,1

# Password Policy
PASSWORD_MIN_LENGTH=12
PASSWORD_CHECK_BREACHED=true

# Two-Factor Authentication
TWO_FACTOR_ENABLED=true
TWO_FACTOR_ISSUER="${APP_NAME}"

# Security Logging
SECURITY_LOGGING_ENABLED=true
SECURITY_LOG_RETENTION_DAYS=90

# Audit Logging
AUDIT_ENABLED=true
AUDIT_RETENTION_DAYS=365

# Compliance (GDPR & Kenya DPA)
GDPR_ENABLED=true
KENYA_DPA_ENABLED=true
DELETION_GRACE_DAYS=30
DATA_RETENTION_YEARS=7

# OAuth (Social Login) — NOT CONFIGURED
# Install laravel/socialite and add provider config to config/services.php
# before adding OAuth env vars here. See CLAUDE.md credential storage rules.

# SAML SSO (Enterprise)
SAML_ENABLED=false
SAML_SP_ENTITY_ID=
SAML_SP_ACS_URL=

# Intrusion Detection
INTRUSION_DETECTION_ENABLED=true
FAILED_LOGIN_THRESHOLD=5
LOCKOUT_DURATION=15

# ===========================================
# PRODUCTION SECURITY (uncomment for production)
# ===========================================

# Content Security Policy (remove unsafe-inline/unsafe-eval for production)
# SECURITY_CSP="default-src 'self'; script-src 'self' https://js.paystack.co; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https://api.paystack.co; frame-ancestors 'none'; base-uri 'self'; form-action 'self';"

# HSTS (enable with HTTPS)
# SECURITY_HSTS_ENABLED=true
# SECURITY_HSTS_PRELOAD=true

# OCR (Water Meter Reading) — NOT CONFIGURED
# Install OCR provider package and add config before adding OCR env vars here.

# ===========================================
# KENYA DPA COMPLIANCE
# ===========================================

# Data Controller Registration Number (from ODPC)
KENYA_DPA_REGISTRATION=
# Email for breach notifications
KENYA_DPA_BREACH_EMAIL=
# ODPC contact
KENYA_DPA_ODPC_EMAIL=info@odpc.go.ke
# Require consent for cross-border data transfer
KENYA_DPA_CROSS_BORDER_CONSENT=true

# ===========================================
# SENTRY (Error Tracking)
# ===========================================

# OBS-1: leave blank in committed .env.example. Empty DSN -> SDK no-op.
# In production, set the DSN from https://sentry.io/settings/.../keys.
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0
# Phase-14 OBSERV-2: deploy.sh stamps this with the target SHA at
# every deploy so Sentry can group errors by release. Leave blank
# locally — SDK falls back to no release tag.
SENTRY_RELEASE=

# Phase-14 OBSERV-1: /metrics Prometheus endpoint gating. Set at
# least one in production (both empty = endpoint returns 503).
# METRICS_BEARER: shared secret for `Authorization: Bearer X`.
# METRICS_ALLOW_IPS: comma-separated CIDRs (e.g. 10.0.0.0/8).
METRICS_BEARER=
METRICS_ALLOW_IPS=

# ===========================================
# FEATURE FLAGS
# ===========================================

# WhatsApp Payment Links (COM-021)
# Enable after Meta approves templates with payment_link variable
WHATSAPP_PAYMENT_LINKS_ENABLED=false
