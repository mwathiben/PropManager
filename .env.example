APP_NAME=PropManager
APP_ENV=local
APP_KEY=
# CRITICAL: Set to false in production!
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_HOST_READ=read-replica.example.com  # Optional: Read replica for heavy read workloads
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
# Set to true in production with HTTPS
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=strict

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# ===========================================
# M-PESA CONFIGURATION (Kenya)
# ===========================================

# Environment: sandbox or production
MPESA_ENVIRONMENT=sandbox

# App credentials from Safaricom Developer Portal
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=

# STK Push (Lipa Na M-Pesa Online)
MPESA_STK_SHORTCODE=174379
MPESA_STK_PASSKEY=
MPESA_STK_CALLBACK_URL="${APP_URL}/webhooks/mpesa/stk-callback"

# C2B (Customer to Business)
MPESA_C2B_SHORTCODE=
MPESA_C2B_VALIDATION_URL="${APP_URL}/webhooks/mpesa/c2b/validation"
MPESA_C2B_CONFIRMATION_URL="${APP_URL}/webhooks/mpesa/c2b/confirmation"

# B2C (Business to Customer - for refunds)
MPESA_B2C_SHORTCODE=
MPESA_B2C_INITIATOR=
MPESA_B2C_PASSWORD=
MPESA_B2C_SECURITY_CREDENTIAL=
MPESA_B2C_RESULT_URL=
MPESA_B2C_TIMEOUT_URL=

# Party B (usually same as shortcode)
MPESA_PARTY_B=
MPESA_ACCOUNT_PREFIX=PROP

# Safaricom IP Whitelist (comma-separated, leave empty to disable)
MPESA_ALLOWED_IPS=196.201.214.200,196.201.214.206,196.201.213.114,196.201.214.207,196.201.214.208,196.201.213.44,196.201.212.127,196.201.212.138,196.201.212.129,196.201.212.136,196.201.212.74,196.201.212.69

VITE_APP_NAME="${APP_NAME}"

# ===========================================
# LARAVEL REVERB (WebSocket Broadcasting)
# ===========================================

REVERB_APP_ID=propmanager
REVERB_APP_KEY=propmanager-key
REVERB_APP_SECRET=your-secret-key-here
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

# Frontend WebSocket connection (Vite)
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ===========================================
# SECURITY CONFIGURATION
# ===========================================

# Security Headers (enable in production with HTTPS)
SECURITY_HSTS_ENABLED=false
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_HSTS_SUBDOMAINS=true
SECURITY_CSP_ENABLED=true
SECURITY_X_FRAME_OPTIONS=DENY

# Rate Limiting (attempts per minute)
RATE_LIMIT_LOGIN=5,1
RATE_LIMIT_REGISTER=3,1
RATE_LIMIT_API=60,1

# Password Policy
PASSWORD_MIN_LENGTH=12
PASSWORD_CHECK_BREACHED=true

# Two-Factor Authentication
TWO_FACTOR_ENABLED=true
TWO_FACTOR_ISSUER="${APP_NAME}"

# Security Logging
SECURITY_LOGGING_ENABLED=true
SECURITY_LOG_RETENTION_DAYS=90

# Audit Logging
AUDIT_ENABLED=true
AUDIT_RETENTION_DAYS=365

# Compliance (GDPR & Kenya DPA)
GDPR_ENABLED=true
KENYA_DPA_ENABLED=true
DELETION_GRACE_DAYS=30
DATA_RETENTION_YEARS=7

# OAuth (Social Login)
OAUTH_ENABLED=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# SAML SSO (Enterprise)
SAML_ENABLED=false
SAML_SP_ENTITY_ID=
SAML_SP_ACS_URL=

# Intrusion Detection
INTRUSION_DETECTION_ENABLED=true
FAILED_LOGIN_THRESHOLD=5
LOCKOUT_DURATION=15

# ===========================================
# PRODUCTION SECURITY (uncomment for production)
# ===========================================

# Content Security Policy (remove unsafe-inline/unsafe-eval for production)
# SECURITY_CSP="default-src 'self'; script-src 'self' https://js.paystack.co; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https://api.paystack.co; frame-ancestors 'none'; base-uri 'self'; form-action 'self';"

# HSTS (enable with HTTPS)
# SECURITY_HSTS_ENABLED=true
# SECURITY_HSTS_PRELOAD=true

# ===========================================
# OCR CONFIGURATION (Water Meter Reading)
# ===========================================

# Provider: none, ocr_space, google_vision, azure_vision, tesseract
# OCR_PROVIDER=none

# OCR.space (recommended - 25,000 free requests/month)
# OCR_SPACE_API_KEY=

# Google Cloud Vision
# GOOGLE_VISION_API_KEY=

# Azure Computer Vision
# AZURE_VISION_API_KEY=
# AZURE_VISION_ENDPOINT=

# ===========================================
# KENYA DPA COMPLIANCE
# ===========================================

# Data Controller Registration Number (from ODPC)
KENYA_DPA_REGISTRATION=
# Email for breach notifications
KENYA_DPA_BREACH_EMAIL=
# ODPC contact
KENYA_DPA_ODPC_EMAIL=info@odpc.go.ke
# Require consent for cross-border data transfer
KENYA_DPA_CROSS_BORDER_CONSENT=true

# ===========================================
# FEATURE FLAGS
# ===========================================

# WhatsApp Payment Links (COM-021)
# Enable after Meta approves templates with payment_link variable
WHATSAPP_PAYMENT_LINKS_ENABLED=false
